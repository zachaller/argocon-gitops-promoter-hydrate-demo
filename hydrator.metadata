  "references": [
    {
      "commit": {
        "author": "\"Zach Aller\" <code@example.com>",
        "date": "2026-04-29T07:05:02-05:00",
        "subject": "fix: remove git@ from GitHub HTTPS repo URLs (#1353)",
        "body": "GetGitHttpsRepoUrl was producing URLs of the form\nhttps://git@github.com/... which partially worked for navigation but\nbroke GitHub sub-pages (e.g. the branches view). Authentication is\nhandled entirely via GIT_ASKPASS env vars, so the git@ prefix was\nunnecessary. This fixes the repoURL written to PromotionStrategy status,\nwhich the UI uses to construct web links.\n\nSigned-off-by: Jonathan Winters <wintersjonathan0@gmail.com>\nCo-authored-by: Claude Sonnet 4.6 <noreply@anthropic.com>",
        "sha": "e43ee43cd12e882ad572f07f7b48e68458a46242",
        "repoUrl": "https://github.com/argoproj-labs/gitops-promoter"
      }
    }
  ]
}
